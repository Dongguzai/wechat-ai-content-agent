# v0.6.0 safe dry-run defaults

# Production-mode real-data gates
REAL_PRODUCTION_MODE=false

# MiniMax Token Plan / text LLM
LLM_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# Fill these with real model ids from the MiniMax console or `pnpm llm:minimax:models`.
# For example, use the model id returned for M3 by the MiniMax console or /v1/models.
MINIMAX_MODEL=
MINIMAX_MAX_COMPLETION_TOKENS=2048
MINIMAX_TEMPERATURE=0.75
ARTICLE_WRITER_PROVIDER=minimax
ARTICLE_WRITER_MODEL=
ARTICLE_WRITER_MAX_COMPLETION_TOKENS=4096
TITLE_GENERATOR_PROVIDER=minimax
TITLE_GENERATOR_MODEL=
TITLE_GENERATOR_MAX_COMPLETION_TOKENS=
ARTICLE_REVIEWER_PROVIDER=minimax
ARTICLE_REVIEWER_MODEL=
ARTICLE_REVIEWER_MAX_COMPLETION_TOKENS=
LLM_ENABLE_REAL_API=false
LLM_DRY_RUN=true

# Search collection
RSS_ENABLE_REAL_FETCH=true
RSS_FETCH_TIMEOUT_MS=5000
RSS_FETCH_RETRY=1
SEARCH_ENABLE_REAL_API=true
SEARCH_FETCH_TIMEOUT_MS=8000
SEARCH_FETCH_RETRY=1
TAVILY_API_KEY=
EXA_API_KEY=
TAVILY_MAX_QUERIES_PER_RUN=6
EXA_MAX_QUERIES_PER_RUN=6
SEARCH_MAX_RESULTS_PER_QUERY=5
SEARCH_LOOKBACK_HOURS=72
NEWS_LOOKBACK_HOURS=72
GLOBAL_SEARCH_MAX_CANDIDATES=6
RSS_MIN_CANDIDATES=14
MIN_REAL_NEWS_ITEMS=20
MIN_REAL_RSS_ITEMS=10
MIN_REAL_SEARCH_ITEMS=3

# Source evidence extraction
SOURCE_EVIDENCE_TIMEOUT_MS=8000
SOURCE_EVIDENCE_MAX_BODY_BYTES=2000000

# Cloud dashboard / Phase 1 daily brief
DATABASE_URL=
DATABASE_MAX_CONNECTIONS=1
# Deprecated/ignored for uploads. Upload endpoint is derived from R2_ACCOUNT_ID.
R2_ENDPOINT=
# Cloudflare account id: 32 hexadecimal characters from the Cloudflare account overview.
# Do not paste a cfat_ API token, access key, bucket name, public URL, or custom domain here.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket name only, for example: briefs. Do not paste R2_ENDPOINT=... here.
R2_BUCKET=
R2_PUBLIC_BASE_URL=
CRON_SECRET=
DASHBOARD_PASSWORD=
AUTH_SECRET=
BRIEF_TIME_ZONE=Asia/Shanghai
# Keep the 7 AM cloud cron under Vercel's function timeout by using rules-based
# news localization. Set CLOUD_BRIEF_REAL_LOCALIZATION=true only if the plan can
# tolerate many per-item LLM calls during brief generation.
CLOUD_BRIEF_REAL_LOCALIZATION=false
NEWS_LOCALIZER_FORCE_RULES=false
NEWS_LOCALIZER_CONCURRENCY=4

# Cover generation
APIMART_API_KEY=
APIMART_IMAGE_API_URL=
APIMART_IMAGE_MODEL=gpt-image-2
APIMART_IMAGE_SIZE=16:9
APIMART_IMAGE_RESOLUTION=2k
APIMART_COVER_STYLE="warm friendly 3D animated movie cover, story-driven, clean composition, clear subject, horizontal 900x383px, prominent Chinese headline inside safe margins"
COVER_ENABLE_REAL_API=false
COVER_IMAGE_PROVIDER=apimart
COVER_IMAGE_SIZE=900x383
COVER_OUTPUT_DIR=outputs/covers

# WeChat browser guardrails
WECHAT_BROWSER_ENABLE_REAL=false
WECHAT_BROWSER_HEADLESS=false
WECHAT_BROWSER_USER_DATA_DIR=.local/wechat-browser-profile
WECHAT_BROWSER_ALLOW_SAVE_DRAFT=false
WECHAT_BROWSER_ALLOW_PREVIEW=false

# WeChat official API draft guardrails
WECHAT_API_ENABLE_REAL_DRAFT=false
WECHAT_DRAFT_ALLOW_REAL_API=false
WECHAT_DRAFT_DRY_RUN=true
WECHAT_FORBID_PUBLISH=true
WECHAT_FORBID_MASS_SEND=true

# WeChat official API credentials and draft fields
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_API_BASE=https://api.weixin.qq.com
WECHAT_AUTHOR=
WECHAT_CONTENT_SOURCE_URL=
WECHAT_COVER_MEDIA_ID=
WECHAT_COVER_IMAGE_PATH=
WECHAT_NEED_OPEN_COMMENT=0
WECHAT_ONLY_FANS_CAN_COMMENT=0

# Daily auto notifications
NOTIFY_ENABLE=false
NOTIFY_METHOD=console
NOTIFY_WEBHOOK_URL=
NOTIFY_EMAIL_TO=
NOTIFY_ON_SUCCESS=false
NOTIFY_ON_FAILURE=true
