{
  "name": "wechat-ai-content-agent",
  "version": "0.6.0",
  "description": "Local-first WeChat AI content production agent with dry-run safety gates.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "env:check": "node --import tsx scripts/check-env.ts",
    "dry-run": "node --import tsx scripts/dry-run.ts",
    "run:daily": "node --import tsx scripts/run-daily.ts",
    "run:daily:auto": "node --import tsx scripts/run-daily-auto.ts",
    "scheduler:install": "node --import tsx scripts/install-cron.ts",
    "scheduler:install-brief": "node --import tsx scripts/install-brief-cron.ts",
    "scheduler:uninstall": "node --import tsx scripts/uninstall-cron.ts",
    "scheduler:uninstall-brief": "node --import tsx scripts/uninstall-brief-cron.ts",
    "scheduler:show": "node --import tsx scripts/show-cron.ts",
    "preflight:final": "node --import tsx scripts/preflight-final.ts",
    "feedback:new": "node --import tsx scripts/create-feedback-template.ts",
    "article:rewrite": "node --import tsx scripts/rewrite-article.ts",
    "cover:regenerate": "node --import tsx scripts/regenerate-cover.ts",
    "llm:minimax:models": "node --import tsx scripts/list-minimax-models.ts",
    "llm:minimax:smoke": "node --import tsx scripts/minimax-smoke.ts",
    "wechat:upload-cover": "node --import tsx scripts/upload-wechat-cover.ts",
    "wechat:draft:dry-run": "WECHAT_DRAFT_DRY_RUN=true WECHAT_API_ENABLE_REAL_DRAFT=false WECHAT_DRAFT_ALLOW_REAL_API=false node --import tsx scripts/push-wechat-draft.ts",
    "wechat:draft:real": "WECHAT_DRAFT_DRY_RUN=false node --import tsx scripts/push-wechat-draft.ts --real",
    "dashboard:dev": "pnpm --filter @wechat-agent/dashboard dev",
    "dashboard:build": "pnpm --filter @wechat-agent/dashboard build",
    "dashboard:start": "pnpm --filter @wechat-agent/dashboard start",
    "dashboard:typecheck": "pnpm --filter @wechat-agent/dashboard typecheck",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit && pnpm dashboard:typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
