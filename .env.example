# v0.4.1 safe dry-run defaults

# Production-mode real-data gates
REAL_PRODUCTION_MODE=false

# Search collection
RSS_ENABLE_REAL_FETCH=true
SEARCH_ENABLE_REAL_API=true
TAVILY_API_KEY=
EXA_API_KEY=
TAVILY_MAX_QUERIES_PER_RUN=6
EXA_MAX_QUERIES_PER_RUN=6
SEARCH_MAX_RESULTS_PER_QUERY=5
SEARCH_LOOKBACK_HOURS=72
GLOBAL_SEARCH_MAX_CANDIDATES=6
RSS_MIN_CANDIDATES=14

# Cover generation
COVER_ENABLE_REAL_API=false
APIMART_API_KEY=
COVER_IMAGE_PROVIDER=apimart
COVER_IMAGE_SIZE=900x383
COVER_OUTPUT_DIR=outputs/covers

# WeChat browser guardrails
WECHAT_BROWSER_ENABLE_REAL=false
WECHAT_BROWSER_HEADLESS=false
WECHAT_BROWSER_USER_DATA_DIR=.local/wechat-browser-profile
WECHAT_BROWSER_ALLOW_SAVE_DRAFT=false
WECHAT_BROWSER_ALLOW_PREVIEW=false

# WeChat official API draft guardrails
WECHAT_API_ENABLE_REAL_DRAFT=false
WECHAT_DRAFT_ALLOW_REAL_API=false
WECHAT_DRAFT_DRY_RUN=true
WECHAT_FORBID_PUBLISH=true
WECHAT_FORBID_MASS_SEND=true

# WeChat official API credentials and draft fields
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_API_BASE=https://api.weixin.qq.com
WECHAT_AUTHOR=
WECHAT_CONTENT_SOURCE_URL=
WECHAT_COVER_MEDIA_ID=
WECHAT_COVER_IMAGE_PATH=
WECHAT_NEED_OPEN_COMMENT=0
WECHAT_ONLY_FANS_CAN_COMMENT=0
